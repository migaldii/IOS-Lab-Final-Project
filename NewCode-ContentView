// ── One row in the friends list ──
struct FriendRow: View {
    let friend  : Friend
    let isShared: Bool
    let onTap   : () -> Void

    var body: some View {
        Button(action: onTap) {
            HStack(spacing: 14) {
                // Emoji avatar
                Text(friend.emoji)
                    .font(.title2)
                    .frame(width: 44, height: 44)
                    .background(Color(.secondarySystemBackground))
                    .clipShape(Circle())

                Text(friend.name)
                    .font(.body.weight(.medium))
                    .foregroundColor(.primary)

                Spacer()

                // Checkmark after sharing, arrow before
                if isShared {
                    Image(systemName: "checkmark.circle.fill")
                        .foregroundColor(.green)
                        .font(.title3)
                } else {
                    Image(systemName: "paperplane.fill")
                        .foregroundColor(.accentColor)
                        .font(.body)
                }
            }
            .padding(14)
            .background(Color(.systemBackground))
            .cornerRadius(14)
            .shadow(color: .black.opacity(0.04), radius: 4, x: 0, y: 1)
        }
    }
}

// ── Article card (2-column grid tile) ──
struct ArticleCard: View {
    let article : SavedArticle
    let onShare : () -> Void

    var body: some View {
        VStack(alignment: .leading, spacing: 0) {

            // Thumbnail with share button
            ZStack(alignment: .topTrailing) {
                ZStack {
                    RoundedRectangle(cornerRadius: 10)
                        .fill(
                            LinearGradient(
                                colors: [Color.accentColor.opacity(0.7), Color.accentColor.opacity(0.3)],
                                startPoint: .topLeading,
                                endPoint: .bottomTrailing
                            )
                        )
                        .frame(height: 100)
                    Image(systemName: "doc.text.fill")
                        .font(.largeTitle)
                        .foregroundColor(.white.opacity(0.85))
                }
                .clipShape(RoundedRectangle(cornerRadius: 10))

                // Share button in top-right corner
                Button(action: onShare) {
                    Image(systemName: "square.and.arrow.up")
                        .font(.caption.weight(.semibold))
                        .foregroundColor(.white)
                        .padding(7)
                        .background(.ultraThinMaterial)
                        .clipShape(Circle())
                }
                .padding(8)
            }

            // Title & URL
            VStack(alignment: .leading, spacing: 4) {
                Text(article.title)
                    .font(.subheadline.weight(.semibold))
                    .lineLimit(3)
                    .foregroundColor(.primary)
                    .padding(.top, 8)

                Text(article.urlString)
                    .font(.caption)
                    .foregroundColor(.secondary)
                    .lineLimit(1)
                    .padding(.top, 2)

                // "Shared with X" badge
                if !article.sharedWith.isEmpty {
                    Text("Shared with \(article.sharedWith.joined(separator: ", "))")
                        .font(.caption2.weight(.medium))
                        .foregroundColor(.accentColor)
                        .padding(.top, 4)
                }
            }
            .padding(.horizontal, 4)
            .padding(.bottom, 12)
        }
        .background(Color(.systemBackground))
        .cornerRadius(14)
        .shadow(color: .black.opacity(0.06), radius: 6, x: 0, y: 2)
    }
}

// ── Full-width row for articles shared BY a friend ──
