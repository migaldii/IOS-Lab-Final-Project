import SwiftUI

// ═════════════════════════════════════════
// MARK: 1.  SHARED DATA STORE
//
// UserDefaults with an App Group lets BOTH the main app
// AND the Share Extension read/write the same data.
// Think of it like a shared notebook between two apps.
//
// ⚠️  Replace "group.com.yourname.thread" with the App Group
//     ID you create in Xcode → Signing & Capabilities.
// ═════════════════════════════════════════

let APP_GROUP = "group.com.yourname.thread"  // ← change this

/// One saved article (stored as a dictionary in UserDefaults)
struct SavedArticle: Identifiable, Codable {
    var id          = UUID()
    var title       : String
    var urlString   : String
    var savedDate   : Date
    var sharedBy    : String?   // nil = saved by me, name = shared by friend
    var sharedWith  : [String]  // friends I forwarded it to
}

/// Simple friend model
struct Friend: Identifiable {
    let id   = UUID()
    let name : String
    let emoji: String           // avatar placeholder
}

/// The friends list (replace with real contacts / backend later)
let myFriends: [Friend] = [
    Friend(name: "Alex",   emoji: "🧢"),
    Friend(name: "Jordan", emoji: "🎧"),
    Friend(name: "Morgan", emoji: "📚"),
    Friend(name: "Taylor", emoji: "🎨"),
    Friend(name: "Riley",  emoji: "🌿"),
]

// ─────────────────────────────────────────
// Helper: read & write saved articles
// ─────────────────────────────────────────

func loadArticles() -> [SavedArticle] {
    let defaults = UserDefaults(suiteName: APP_GROUP)
    guard
        let data = defaults?.data(forKey: "savedArticles"),
        let decoded = try? JSONDecoder().decode([SavedArticle].self, from: data)
    else { return [] }
    return decoded
}

func saveArticles(_ articles: [SavedArticle]) {
    let defaults = UserDefaults(suiteName: APP_GROUP)
    if let encoded = try? JSONEncoder().encode(articles) {
        defaults?.set(encoded, forKey: "savedArticles")
    }
}

// ═════════════════════════════════════════
// MARK: 2.  CONTENT VIEW  (Home Screen)
// ═════════════════════════════════════════

struct ContentView: View {

    // All saved articles, loaded from shared storage
    @State private var articles: [SavedArticle] = []

    // Which article the user wants to share with a friend
    @State private var articleToShare: SavedArticle? = nil

    // Reload articles every time the app comes to the foreground
    // (so new saves from the Share Extension appear immediately)
    @Environment(\.scenePhase) private var scenePhase

    // Articles I saved myself (no sharedBy value)
    var mySaves: [SavedArticle] {
        articles.filter { $0.sharedBy == nil }
    }

    // Articles friends sent me
    var sharedWithMe: [SavedArticle] {
        articles.filter { $0.sharedBy != nil }
    }

    var body: some View {
        NavigationView {
            Group {
                if articles.isEmpty {
                    // ── Empty state ──
                    EmptyStateView()
                } else {
                    // ── Article lists ──
                    ScrollView {
                        VStack(alignment: .leading, spacing: 0) {

                            // Recently Saved section
                            if !mySaves.isEmpty {
                                SectionHeader(title: "Recently Saved", icon: "📌")
                                    .padding(.horizontal)
                                    .padding(.top, 24)

                                LazyVGrid(
                                    columns: [GridItem(.flexible()), GridItem(.flexible())],
                                    spacing: 16
                                ) {
                                    ForEach(mySaves) { article in
                                        ArticleCard(article: article) {
                                            articleToShare = article
                                        }
                                    }
                                }
                                .padding(.horizontal)
                                .padding(.top, 12)
                            }

                            // Shared With You section
                            if !sharedWithMe.isEmpty {
                                SectionHeader(title: "Shared With You", icon: "🔗")
                                    .padding(.horizontal)
                                    .padding(.top, 32)

                                VStack(spacing: 12) {
                                    ForEach(sharedWithMe) { article in
                                        SharedArticleRow(article: article) {
                                            articleToShare = article
                                        }
                                    }
                                }
                                .padding(.horizontal)
                                .padding(.top, 12)
                            }

                            Spacer(minLength: 40)
                        }
                    }
                }
            }
            .background(Color(.systemGroupedBackground))
            .navigationTitle("Thread")
            .navigationBarTitleDisplayMode(.large)
        }
        // Load articles when app opens
        .onAppear {
            articles = loadArticles()
        }
        // Reload when app comes back from background
        .onChange(of: scenePhase) { phase in
            if phase == .active {
                articles = loadArticles()
            }
        }
        // Share-with-friend sheet
        .sheet(item: $articleToShare) { article in
            ShareWithFriendView(article: article) { updatedArticle in
                // After sharing, update that article in our list
                if let index = articles.firstIndex(where: { $0.id == updatedArticle.id }) {
                    articles[index] = updatedArticle
                    saveArticles(articles)
                }
            }
        }
    }
}

// ═════════════════════════════════════════
// MARK: 3.  SHARE WITH FRIEND VIEW
//
// This popup appears when the user taps the share button
// on any saved article. It shows the friends list and
// lets them pick who to send it to.
// ═════════════════════════════════════════

struct ShareWithFriendView: View {
    let article   : SavedArticle
    let onShared  : (SavedArticle) -> Void   // called after sharing

    @Environment(\.dismiss) private var dismiss

    // Which friend the user just tapped (shows a checkmark)
    @State private var justSharedWith: String? = nil

    var body: some View {
        NavigationView {
            VStack(spacing: 0) {

                // Article preview at the top
                ArticlePreviewBanner(article: article)
                    .padding()

                Divider()

                // "Send to a friend" label
                Text("Send to a friend")
                    .font(.caption.weight(.semibold))
                    .foregroundColor(.secondary)
                    .frame(maxWidth: .infinity, alignment: .leading)
                    .padding(.horizontal)
                    .padding(.top, 20)
                    .padding(.bottom, 8)

                // Friends list
                ScrollView {
                    VStack(spacing: 10) {
                        ForEach(myFriends) { friend in
                            FriendRow(
                                friend: friend,
                                isShared: justSharedWith == friend.name
                            ) {
                                shareTo(friend: friend)
                            }
                        }
                    }
                    .padding(.horizontal)
                }

                Spacer()
            }
            .background(Color(.systemGroupedBackground))
            .navigationTitle("Share Article")
            .navigationBarTitleDisplayMode(.inline)
            .toolbar {
                ToolbarItem(placement: .navigationBarTrailing) {
                    Button("Done") { dismiss() }
                }
            }
        }
    }

    // Called when the user taps a friend row
    private func shareTo(friend: Friend) {
        justSharedWith = friend.name

        // Update the article to record who we shared it with
        var updated = article
        if !updated.sharedWith.contains(friend.name) {
            updated.sharedWith.append(friend.name)
        }
        onShared(updated)

        // Dismiss after a short delay so the user sees the checkmark
        DispatchQueue.main.asyncAfter(deadline: .now() + 1.0) {
            dismiss()
        }
    }
}

