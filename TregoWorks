    static let savedArticlesKey = "savedArticles"
    static let foldersKey = "articleFolders"
}

struct SavedArticle: Identifiable, Codable, Hashable {
    var id: String
    var title: String
    var urlString: String
    var savedDate: Date
    var sharedBy: String?
    var sharedWith: [String]
    var folderName: String?
    var keywords: [String]
    var summary: String?

    init(
        id: String = UUID().uuidString,
        title: String,
        urlString: String,
        savedDate: Date,
        sharedBy: String? = nil,
        sharedWith: [String] = [],
        folderName: String? = nil,
        keywords: [String] = [],
        summary: String? = nil
    ) {
        self.id = id
        self.title = title
        self.urlString = urlString
        self.savedDate = savedDate
        self.sharedBy = sharedBy
        self.sharedWith = sharedWith
        self.folderName = folderName
        self.keywords = keywords
        self.summary = summary
    }

    init(from decoder: Decoder) throws {
        let container = try decoder.container(keyedBy: CodingKeys.self)
        id = try container.decodeIfPresent(String.self, forKey: .id) ?? UUID().uuidString
        title = try container.decode(String.self, forKey: .title)
        urlString = try container.decode(String.self, forKey: .urlString)
        savedDate = try container.decode(Date.self, forKey: .savedDate)
        sharedBy = try container.decodeIfPresent(String.self, forKey: .sharedBy)
        sharedWith = try container.decodeIfPresent([String].self, forKey: .sharedWith) ?? []
        folderName = try container.decodeIfPresent(String.self, forKey: .folderName)
        keywords = try container.decodeIfPresent([String].self, forKey: .keywords) ?? []
        summary = try container.decodeIfPresent(String.self, forKey: .summary)
    }

    var url: URL? {
        URL(string: urlString)
    }

    var hostLabel: String {
        url?.host() ?? urlString
    }

    var effectiveFolderName: String {
        if let folderName, !folderName.isEmpty {
            return folderName
        }

        return "Un-Categorized"
    }
    
}

private enum NavigationSection: String, CaseIterable, Hashable {
    case home = "Home"
    case folders = "Folders"
    case keywords = "Keywords"
    

    var systemImage: String {
        switch self {
        case .home:
            return "house.fill"
        case .folders:
            return "folder.fill"
        case .keywords:
            return "tag.fill"
        }
    }
}

private enum FolderFilter: Hashable {
    case all
    case unfiled
    case named(String)

    var title: String {
        switch self {
        case .all:
            return "All"
        case .unfiled:
            return "Un-Catergorized"
        case .named(let name):
            return name
        }
    }
}

@MainActor
final class ArticleStore: ObservableObject {
    @Published private(set) var articles: [SavedArticle] = []
    @Published private(set) var folders: [String] = []
    @Published private(set) var isSharedStorageAvailable = true

    private let decoder = JSONDecoder()
    private let encoder = JSONEncoder()

    func reload() {
        guard let defaults = UserDefaults(suiteName: ThreadSharedConfig.appGroupID) else {
            isSharedStorageAvailable = false
            articles = []
            folders = []
            return
        }

        isSharedStorageAvailable = true

        if let data = defaults.data(forKey: ThreadSharedConfig.savedArticlesKey),
           let decoded = try? decoder.decode([SavedArticle].self, from: data) {
            articles = decoded.sorted(by: { $0.savedDate > $1.savedDate })
        } else {
            articles = []
        }

        if let data = defaults.data(forKey: ThreadSharedConfig.foldersKey),
           let decoded = try? decoder.decode([String].self, from: data) {
            folders = decoded.sorted()
        } else {
            folders = []
        }

        syncFoldersFromArticles()
    }

    func createFolder(named rawName: String) {
        let folderName = normalizedValue(rawName)
        guard !folderName.isEmpty else { return }
        guard !folders.contains(folderName) else { return }

        folders.append(folderName)
        folders.sort()
        persistFolders()
    }

    func updateArticle(
        _ article: SavedArticle,
        folder: String?,
        keywords: [String]
    ) {
        guard let index = articles.firstIndex(where: { $0.id == article.id }) else {
            return
        }

        let normalizedFolder = normalizedValue(folder)
        if !normalizedFolder.isEmpty {
            createFolder(named: normalizedFolder)
        }

        articles[index].folderName = normalizedFolder.isEmpty ? nil : normalizedFolder
        articles[index].keywords = normalizedKeywords(keywords)
        persistArticles()
        syncFoldersFromArticles()
    }

    func keywordCounts() -> [(keyword: String, count: Int)] {
        let counts = articles
            .flatMap(\.keywords)
            .reduce(into: [String: Int]()) { partialResult, keyword in
                partialResult[keyword, default: 0] += 1
            }

        return counts.keys.sorted().map { ($0, counts[$0] ?? 0) }
    }

    private func syncFoldersFromArticles() {
        let articleFolders = articles.compactMap(\.folderName).filter { !$0.isEmpty }
        folders = Array(Set(folders).union(articleFolders)).sorted()
        persistFolders()
    }

    private func persistArticles() {
        guard let defaults = UserDefaults(suiteName: ThreadSharedConfig.appGroupID) else {
            isSharedStorageAvailable = false
            return
        }

        isSharedStorageAvailable = true
        articles = articles.sorted(by: { $0.savedDate > $1.savedDate })

        guard let data = try? encoder.encode(articles) else {
            return
        }

        defaults.set(data, forKey: ThreadSharedConfig.savedArticlesKey)
    }

    private func persistFolders() {
        guard let defaults = UserDefaults(suiteName: ThreadSharedConfig.appGroupID) else {
            isSharedStorageAvailable = false
            return
        }

        isSharedStorageAvailable = true
        folders = folders.sorted()

        guard let data = try? encoder.encode(folders) else {
            return
        }

        defaults.set(data, forKey: ThreadSharedConfig.foldersKey)
    }

    private func normalizedKeywords(_ keywords: [String]) -> [String] {
        let tokens = keywords
            .map(normalizedValue)
            .filter { !$0.isEmpty }

        return Array(NSOrderedSet(array: tokens)) as? [String] ?? tokens
    }

    private func normalizedValue(_ value: String?) -> String {
        value?.trimmingCharacters(in: .whitespacesAndNewlines) ?? ""
    }
}

struct ContentView: View {
    @Environment(\.scenePhase) private var scenePhase
    @Environment(\.horizontalSizeClass) private var horizontalSizeClass
    @Environment(\.openURL) private var openURL

    @StateObject private var store = ArticleStore()
    @State private var searchText = ""
    @State private var selectedSection: NavigationSection = .home
    @State private var selectedFilter: FolderFilter = .all
    @State private var selectedKeyword: String?
    @State private var articleToShare: SavedArticle?
    @State private var articleToEdit: SavedArticle?
    @State private var isShowingCreateFolderSheet = false

    private var folderFilters: [FolderFilter] {
        [.all, .unfiled] + store.folders.map(FolderFilter.named)
    }

    private var filteredArticles: [SavedArticle] {
        store.articles.filter { article in
            matchesSearch(article) && matchesFolder(article) && matchesKeyword(article)
        }
    }

    private var mySaves: [SavedArticle] {
        filteredArticles.filter { $0.sharedBy == nil }
    }

    private var sharedWithMe: [SavedArticle] {
        filteredArticles.filter { $0.sharedBy != nil }
    }

    private var gridColumns: [GridItem] {
        let count = horizontalSizeClass == .regular ? 2 : 1
        return Array(repeating: GridItem(.flexible(), spacing: 16), count: count)
    }

    private var keywordCounts: [(keyword: String, count: Int)] {
        store.keywordCounts()
    }

    var body: some View {
        NavigationStack {
            ScrollView {
                VStack(alignment: .leading, spacing: 20) {
                    SectionNavigationBar(selectedSection: $selectedSection)
                    
                    if selectedSection == .folders {
                        FolderFilterBar(filters: folderFilters, selectedFilter: $selectedFilter)
                    }
                    
                    if selectedSection == .keywords {
                        KeywordFilterBar(
                            keywords: keywordCounts,
                            selectedKeyword: $selectedKeyword
                        )
                    }
                    
                    FolderSummaryCard(
                        title: summaryTitle,
                        subtitle: summarySubtitle,
                        count: filteredArticles.count
                    )
                    
                    contentView
                }
                .padding(20)
            }
            .background(Color.white)
            .navigationTitle("Thread")
            .searchable(text: $searchText, prompt: "Search titles, folders, keywords, or sites")
            .toolbar {
                ToolbarItem(placement: .topBarTrailing) {
                    Button {
                        isShowingCreateFolderSheet = true
                    } label: {
                        Label("New Folder", systemImage: "folder.badge.plus")
                    }
                }
            }
            
            .safeAreaInset(edge: .bottom) {
                if !store.isSharedStorageAvailable {
                    SharedStorageWarning()
                }
            }
//            @ViewBuilder
//             var contentView: some View {
//                .background(Color.white)
//                .navigationTitle("Thread")
//                .searchable(text: $searchText, prompt: "Search titles, folders, keywords, or sites")
//                .toolbar {
//                    ToolbarItem(placement: .topBarTrailing) {
//                        Button {
//                            isShowingCreateFolderSheet = true
//                        } label: {
//                            Label("New Folder", systemImage: "folder.badge.plus")
//                        }
//                    }
//                }
//                
//                .safeAreaInset(edge: .bottom) {
//                    if !store.isSharedStorageAvailable {
//                        SharedStorageWarning()
//                    }
//                }
//            }
            .sheet(item: $articleToShare) { article in
                ActivityViewController(items: shareItems(for: article))
            }
            .sheet(item: $articleToEdit) { article in
                ArticleMetadataEditor(
                    article: article,
                    folders: store.folders,
                    onSave: { folderName, keywords in
                        store.updateArticle(article, folder: folderName, keywords: keywords)
                    },
                    onCreateFolder: { folderName in
                        store.createFolder(named: folderName)
                    }
                )
            }
            .sheet(isPresented: $isShowingCreateFolderSheet) {
                CreateFolderView { folderName in
                    store.createFolder(named: folderName)
                }
            }
            .onAppear {
                store.reload()
            }
            .onChange(of: scenePhase) { _, newPhase in
                if newPhase == .active {
                    store.reload()
                }
            }
            .onChange(of: store.folders) { _, folders in
                if case .named(let name) = selectedFilter, !folders.contains(name) {
                    selectedFilter = .all
                }
            }
            .onChange(of: selectedSection) { _, newValue in
                switch newValue {
                case .home:
                    selectedFilter = .all
                    selectedKeyword = nil
                case .folders:
                    selectedKeyword = nil
                case .keywords:
                    selectedFilter = .all
                case .share:
                    selectedFilter = .all
                }
            }
        }
    }

    @ViewBuilder
    private var contentView: some View {
        if filteredArticles.isEmpty {
            EmptyStateView(
                isSearching: !searchText.isEmpty,
                selectedSection: selectedSection,
                onReset: resetNavigation
            )
        } else {
            if selectedSection == .keywords {
                KeywordOverviewSection(
                    keywords: keywordCounts,
                    selectedKeyword: $selectedKeyword
                )
            }

            if !mySaves.isEmpty {
                VStack(alignment: .leading, spacing: 12) {
                    SectionHeader(
                        title: "Saved",
                        subtitle: "Articles captured from Safari"
                    )

                    LazyVGrid(columns: gridColumns, spacing: 16) {
                        ForEach(mySaves) { article in
                            ArticleCard(
                                article: article,
                                onOpen: { openArticle(article) },
                                onShare: { articleToShare = article },
                                onEdit: { articleToEdit = article }
                            )
                        }
                    }
                }
            }

            if !sharedWithMe.isEmpty {
                VStack(alignment: .leading, spacing: 12) {
                    SectionHeader(
                        title: "Shared With You",
                        subtitle: "Articles from people in your network"
                    )

                    ForEach(sharedWithMe) { article in
                        SharedArticleRow(
                            article: article,
                            onOpen: { openArticle(article) },
                            onShare: { articleToShare = article },
                            onEdit: { articleToEdit = article }
                        )
                    }
                }
            }
        }
    }

    private var summaryTitle: String {
        switch selectedSection {
        case .home:
            return "Library"
        case .folders:
            return selectedFilter.title
        case .keywords:
            return selectedKeyword ?? "Keywords"
        case .share:
            return "Share"
        }
    }

    private var summarySubtitle: String {
        switch selectedSection {
        case .home:
            return "Browse everything you have saved"
        case .folders:
            return "Filter by folder without losing your way back"
        case .keywords:
            return "Filter by the keywords you attach to articles"
        case .share:
            return "Content Shared With You"
        }
    }

    private func resetNavigation() {
        selectedSection = .home
        selectedFilter = .all
        selectedKeyword = nil
        searchText = ""
    }

    private func matchesSearch(_ article: SavedArticle) -> Bool {
        guard !searchText.isEmpty else { return true }

        return article.title.localizedCaseInsensitiveContains(searchText)
            || article.urlString.localizedCaseInsensitiveContains(searchText)
            || article.hostLabel.localizedCaseInsensitiveContains(searchText)
            || article.effectiveFolderName.localizedCaseInsensitiveContains(searchText)
            || article.keywords.contains(where: { $0.localizedCaseInsensitiveContains(searchText) })
            || (article.summary?.localizedCaseInsensitiveContains(searchText) ?? false)
    }

    private func matchesFolder(_ article: SavedArticle) -> Bool {
        guard selectedSection != .keywords else { return true }

        switch selectedFilter {
        case .all:
            return true
        case .unfiled:
            return article.folderName == nil || article.folderName?.isEmpty == true
        case .named(let name):
            return article.folderName == name
        }
    }

    private func matchesKeyword(_ article: SavedArticle) -> Bool {
        guard selectedSection == .keywords, let selectedKeyword else { return true }
        return article.keywords.contains(selectedKeyword)
    }

    private func openArticle(_ article: SavedArticle) {
        guard let url = article.url else { return }
        openURL(url)
    }

    private func shareItems(for article: SavedArticle) -> [Any] {
        var items: [Any] = [article.title]

        if let summary = article.summary, !summary.isEmpty {
            items.append(summary)
        }

        if let url = article.url {
            items.append(url)
        }

        return items
    }
}

