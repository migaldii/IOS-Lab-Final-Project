// ShareViewController.swift
// FILE 2 of 2  →  Goes in your SHARE EXTENSION target
//
// This is the code that makes "Thread" appear in Safari's
// share sheet. When the user taps the Thread icon:
//   1. A popup appears showing the article title & URL
//   2. They see a "Save + Share" button
//   3. The article is saved to shared storage
//   4. They can pick a friend to share it with right away
//
// HOW TO ADD THIS TO XCODE:
//   File → New → Target → Share Extension → Name it "ThreadShare"
//   Replace the generated ShareViewController.swift with this file.
//   In BOTH targets add App Groups capability with the same group ID.
// ─────────────────────────────────────────────────────────────────

import UIKit
import Social
import UniformTypeIdentifiers

// ⚠️  Must match the APP_GROUP string in ContentView.swift
private let APP_GROUP = "group.com.yourname.thread"

// Friends list — keep in sync with ContentView.swift
private let friends = [
    ("Alex",   "🧢"),
    ("Jordan", "🎧"),
    ("Morgan", "📚"),
    ("Taylor", "🎨"),
    ("Riley",  "🌿"),
]

// ═════════════════════════════════════════
// MARK: ShareViewController
// ═════════════════════════════════════════

class ShareViewController: UIViewController {

    // ── State ──────────────────────────────
    private var resolvedURL  : String = ""
    private var resolvedTitle: String = ""
    private var selectedFriend: String? = nil

    // ── UI Elements ────────────────────────
    private let dimView          = UIView()
    private let card             = UIView()
    private let handleBar        = UIView()
    private let appLabel         = UILabel()
    private let titleLabel       = UILabel()
    private let urlLabel         = UILabel()
    private let friendsLabel     = UILabel()
    private let friendsStack     = UIStackView()
    private let saveButton       = UIButton(type: .system)
    private let cancelButton     = UIButton(type: .system)

    // ═════════════════════════════════════════
    // MARK: viewDidLoad — called when extension opens
    // ═════════════════════════════════════════

    override func viewDidLoad() {
        super.viewDidLoad()
        buildUI()
        extractURLFromSafari()   // pull the page URL & title out of the share payload
    }

    override func viewDidAppear(_ animated: Bool) {
        super.viewDidAppear(animated)
        slideCardUp()
    }

    // ═════════════════════════════════════════
    // MARK: Build the UI
    // ═════════════════════════════════════════

    private func buildUI() {

        // Semi-transparent background behind the card
        dimView.backgroundColor = UIColor.black.withAlphaComponent(0.45)
        dimView.translatesAutoresizingMaskIntoConstraints = false
        view.addSubview(dimView)
        NSLayoutConstraint.activate([
            dimView.topAnchor.constraint(equalTo: view.topAnchor),
            dimView.bottomAnchor.constraint(equalTo: view.bottomAnchor),
            dimView.leadingAnchor.constraint(equalTo: view.leadingAnchor),
            dimView.trailingAnchor.constraint(equalTo: view.trailingAnchor),
        ])

        // Tap the dim area to cancel
        dimView.addGestureRecognizer(
            UITapGestureRecognizer(target: self, action: #selector(cancel))
        )

        // ── White card that slides up from the bottom ──
        card.backgroundColor    = .systemBackground
        card.layer.cornerRadius = 20
        card.layer.maskedCorners = [.layerMinXMinYCorner, .layerMaxXMinYCorner]
        card.translatesAutoresizingMaskIntoConstraints = false
        view.addSubview(card)
        NSLayoutConstraint.activate([
            card.leadingAnchor.constraint(equalTo: view.leadingAnchor),
            card.trailingAnchor.constraint(equalTo: view.trailingAnchor),
            card.bottomAnchor.constraint(equalTo: view.bottomAnchor),
        ])

        // Start the card off-screen below (animates up in slideCardUp)
        card.transform = CGAffineTransform(translationX: 0, y: 500)

        // ── Handle bar at top of card ──
        handleBar.backgroundColor   = UIColor.systemGray4
        handleBar.layer.cornerRadius = 3
        handleBar.translatesAutoresizingMaskIntoConstraints = false
        card.addSubview(handleBar)

        // ── "Thread" app name label ──
        appLabel.text      = "🧵 Thread"
        appLabel.font      = .systemFont(ofSize: 17, weight: .bold)
        appLabel.textColor = .label
        appLabel.translatesAutoresizingMaskIntoConstraints = false
        card.addSubview(appLabel)

        // ── Article title ──
        titleLabel.text          = "Detecting article..."
        titleLabel.font          = .systemFont(ofSize: 15, weight: .semibold)
        titleLabel.textColor     = .label
        titleLabel.numberOfLines = 2
        titleLabel.translatesAutoresizingMaskIntoConstraints = false
        card.addSubview(titleLabel)

        // ── URL ──
        urlLabel.text          = ""
        urlLabel.font          = .systemFont(ofSize: 12)
        urlLabel.textColor     = .secondaryLabel
        urlLabel.numberOfLines = 1
        urlLabel.translatesAutoresizingMaskIntoConstraints = false
        card.addSubview(urlLabel)

        // ── "Share with a friend" label ──
        friendsLabel.text      = "Share with a friend"
        friendsLabel.font      = .systemFont(ofSize: 13, weight: .semibold)
        friendsLabel.textColor = .secondaryLabel
        friendsLabel.translatesAutoresizingMaskIntoConstraints = false
        card.addSubview(friendsLabel)

        // ── Horizontal friends scroll row ──
        friendsStack.axis      = .horizontal
        friendsStack.spacing   = 12
        friendsStack.alignment = .center
        friendsStack.translatesAutoresizingMaskIntoConstraints = false

        for (name, emoji) in friends {
            let btn = makeFriendButton(name: name, emoji: emoji)
            friendsStack.addArrangedSubview(btn)
        }

        // Wrap in scroll view so it scrolls if many friends
        let scrollView = UIScrollView()
        scrollView.showsHorizontalScrollIndicator = false
        scrollView.translatesAutoresizingMaskIntoConstraints = false
        scrollView.addSubview(friendsStack)
        card.addSubview(scrollView)

        NSLayoutConstraint.activate([
            friendsStack.topAnchor.constraint(equalTo: scrollView.topAnchor),
            friendsStack.bottomAnchor.constraint(equalTo: scrollView.bottomAnchor),
            friendsStack.leadingAnchor.constraint(equalTo: scrollView.leadingAnchor),
            friendsStack.trailingAnchor.constraint(equalTo: scrollView.trailingAnchor),
            friendsStack.heightAnchor.constraint(equalTo: scrollView.heightAnchor),
        ])

        // ── Save button ──
        saveButton.setTitle("Save to Thread", for: .normal)
        saveButton.titleLabel?.font = .systemFont(ofSize: 17, weight: .semibold)
        saveButton.setTitleColor(.white, for: .normal)
        saveButton.backgroundColor  = .systemBlue
        saveButton.layer.cornerRadius = 14
        saveButton.addTarget(self, action: #selector(saveArticle), for: .touchUpInside)
        saveButton.translatesAutoresizingMaskIntoConstraints = false
        card.addSubview(saveButton)

        // ── Cancel button ──
        cancelButton.setTitle("Cancel", for: .normal)
        cancelButton.titleLabel?.font = .systemFont(ofSize: 16)
        cancelButton.setTitleColor(.secondaryLabel, for: .normal)
        cancelButton.addTarget(self, action: #selector(cancel), for: .touchUpInside)
        cancelButton.translatesAutoresizingMaskIntoConstraints = false
        card.addSubview(cancelButton)

        // ── Layout all elements inside the card ──
        NSLayoutConstraint.activate([

            handleBar.topAnchor.constraint(equalTo: card.topAnchor, constant: 12),
            handleBar.centerXAnchor.constraint(equalTo: card.centerXAnchor),
            handleBar.widthAnchor.constraint(equalToConstant: 40),
            handleBar.heightAnchor.constraint(equalToConstant: 5),

            appLabel.topAnchor.constraint(equalTo: handleBar.bottomAnchor, constant: 20),
            appLabel.leadingAnchor.constraint(equalTo: card.leadingAnchor, constant: 24),

            titleLabel.topAnchor.constraint(equalTo: appLabel.bottomAnchor, constant: 16),
            titleLabel.leadingAnchor.constraint(equalTo: card.leadingAnchor, constant: 24),
            titleLabel.trailingAnchor.constraint(equalTo: card.trailingAnchor, constant: -24),

            urlLabel.topAnchor.constraint(equalTo: titleLabel.bottomAnchor, constant: 6),
            urlLabel.leadingAnchor.constraint(equalTo: card.leadingAnchor, constant: 24),
            urlLabel.trailingAnchor.constraint(equalTo: card.trailingAnchor, constant: -24),

            friendsLabel.topAnchor.constraint(equalTo: urlLabel.bottomAnchor, constant: 24),
            friendsLabel.leadingAnchor.constraint(equalTo: card.leadingAnchor, constant: 24),

            scrollView.topAnchor.constraint(equalTo: friendsLabel.bottomAnchor, constant: 12),
            scrollView.leadingAnchor.constraint(equalTo: card.leadingAnchor, constant: 24),
            scrollView.trailingAnchor.constraint(equalTo: card.trailingAnchor, constant: -24),
            scrollView.heightAnchor.constraint(equalToConstant: 80),

            saveButton.topAnchor.constraint(equalTo: scrollView.bottomAnchor, constant: 24),
            saveButton.leadingAnchor.constraint(equalTo: card.leadingAnchor, constant: 24),
            saveButton.trailingAnchor.constraint(equalTo: card.trailingAnchor, constant: -24),
            saveButton.heightAnchor.constraint(equalToConstant: 52),

            cancelButton.topAnchor.constraint(equalTo: saveButton.bottomAnchor, constant: 10),
            cancelButton.centerXAnchor.constraint(equalTo: card.centerXAnchor),
            cancelButton.heightAnchor.constraint(equalToConstant: 44),
            cancelButton.bottomAnchor.constraint(equalTo: view.safeAreaLayoutGuide.bottomAnchor, constant: -8),
        ])
    }

    // ── Creates one circular friend button ──
    private func makeFriendButton(name: String, emoji: String) -> UIView {
        let container  = UIView()
        container.translatesAutoresizingMaskIntoConstraints = false

        let circle = UIButton(type: .system)
        circle.setTitle(emoji, for: .normal)
        circle.titleLabel?.font = .systemFont(ofSize: 24)
        circle.backgroundColor  = UIColor.systemGray6
        circle.layer.cornerRadius = 28
        circle.layer.borderWidth  = 2
        circle.layer.borderColor  = UIColor.clear.cgColor
        circle.translatesAutoresizingMaskIntoConstraints = false
        circle.accessibilityLabel = name
        circle.addTarget(self, action: #selector(friendTapped(_:)), for: .touchUpInside)

        let label = UILabel()
        label.text      = name
        label.font      = .systemFont(ofSize: 11, weight: .medium)
        label.textColor = .secondaryLabel
        label.textAlignment = .center
        label.translatesAutoresizingMaskIntoConstraints = false

        container.addSubview(circle)
        container.addSubview(label)

        NSLayoutConstraint.activate([
            circle.topAnchor.constraint(equalTo: container.topAnchor),
            circle.centerXAnchor.constraint(equalTo: container.centerXAnchor),
            circle.widthAnchor.constraint(equalToConstant: 56),
            circle.heightAnchor.constraint(equalToConstant: 56),

            label.topAnchor.constraint(equalTo: circle.bottomAnchor, constant: 4),
            label.centerXAnchor.constraint(equalTo: container.centerXAnchor),
            label.bottomAnchor.constraint(equalTo: container.bottomAnchor),
            label.widthAnchor.constraint(equalToConstant: 60),
        ])

        return container
    }

    // ═════════════════════════════════════════
    // MARK: Extract URL from Safari share payload
    // ═════════════════════════════════════════

    private func extractURLFromSafari() {
        // The share payload arrives as an NSExtensionItem
        guard
            let item       = extensionContext?.inputItems.first as? NSExtensionItem,
            let providers  = item.attachments
        else { return }

        // Try to grab the page title
        resolvedTitle = item.attributedTitle?.string
                     ?? item.attributedContentText?.string
                     ?? "Untitled Article"

        // Walk the providers looking for a URL
        for provider in providers {
            if provider.hasItemConformingToTypeIdentifier(UTType.url.identifier) {
                provider.loadItem(forTypeIdentifier: UTType.url.identifier) { [weak self] item, _ in
                    guard let self = self else { return }
                    let urlString = (item as? URL)?.absoluteString
                                 ?? (item as? String)
                                 ?? ""
                    DispatchQueue.main.async {
                        self.resolvedURL = urlString
                        self.titleLabel.text = self.resolvedTitle.isEmpty ? urlString : self.resolvedTitle
                        self.urlLabel.text   = urlString
                    }
                }
                return
            }
        }
    }

    // ═════════════════════════════════════════
    // MARK: Actions
    // ═════════════════════════════════════════

    // Called when user taps a friend circle
    @objc private func friendTapped(_ sender: UIButton) {
        let name = sender.accessibilityLabel ?? ""
        selectedFriend = name

        // Highlight the tapped button, reset others
        for sub in friendsStack.arrangedSubviews {
            if let circle = sub.subviews.first(where: { $0 is UIButton }) as? UIButton {
                circle.layer.borderColor = UIColor.clear.cgColor
                circle.backgroundColor   = UIColor.systemGray6
            }
        }
        sender.layer.borderColor = UIColor.systemBlue.cgColor
        sender.backgroundColor   = UIColor.systemBlue.withAlphaComponent(0.1)

        // Update save button to reflect friend selection
        saveButton.setTitle("Save & Send to \(name)", for: .normal)
    }

    // Called when user taps Save
    @objc private func saveArticle() {
        guard !resolvedURL.isEmpty else {
            titleLabel.text = "⚠️ Could not find a link on this page"
            return
        }

        // Build the article object
        let newArticle = SavedArticleData(
            id         : UUID().uuidString,
            title      : resolvedTitle.isEmpty ? resolvedURL : resolvedTitle,
            urlString  : resolvedURL,
            savedDate  : ISO8601DateFormatter().string(from: Date()),
            sharedBy   : nil,
            sharedWith : selectedFriend.map { [$0] } ?? []
        )

        // Write to shared UserDefaults so the main app can read it
        let defaults = UserDefaults(suiteName: APP_GROUP)
        var existing = defaults?.array(forKey: "savedArticlesRaw") as? [[String: Any]] ?? []
        existing.insert(newArticle.toDictionary(), at: 0)   // newest first
        defaults?.set(existing, forKey: "savedArticlesRaw")

        // Also write using the Codable format ContentView uses
        saveUsingCodable(newArticle)

        // Visual confirmation then close
        saveButton.setTitle("Saved! ✓", for: .normal)
        saveButton.backgroundColor = .systemGreen

        DispatchQueue.main.asyncAfter(deadline: .now() + 0.8) {
            self.extensionContext?.completeRequest(returningItems: nil)
        }
    }

    // Writes the article in the same Codable format ContentView reads
    private func saveUsingCodable(_ data: SavedArticleData) {
        let defaults = UserDefaults(suiteName: APP_GROUP)
        var articles: [SavedArticleCodable] = []

        if let existing = defaults?.data(forKey: "savedArticles"),
           let decoded = try? JSONDecoder().decode([SavedArticleCodable].self, from: existing) {
            articles = decoded
        }

        let article = SavedArticleCodable(
            id         : data.id,
            title      : data.title,
            urlString  : data.urlString,
            savedDate  : Date(),
            sharedBy   : nil,
            sharedWith : data.sharedWith
        )

        articles.insert(article, at: 0)

        if let encoded = try? JSONEncoder().encode(articles) {
            defaults?.set(encoded, forKey: "savedArticles")
        }
    }

    @objc private func cancel() {
        extensionContext?.cancelRequest(withError: NSError(
            domain: "ThreadShare",
            code: 0,
            userInfo: [NSLocalizedDescriptionKey: "Cancelled"]
        ))
    }

    // ═════════════════════════════════════════
    // MARK: Animation
    // ═════════════════════════════════════════

    private func slideCardUp() {
        UIView.animate(
            withDuration: 0.4,
            delay: 0,
            usingSpringWithDamping: 0.85,
            initialSpringVelocity: 0.5
        ) {
            self.card.transform = .identity
        }
    }
}

// ═════════════════════════════════════════
// MARK: Helper data structs (used only inside this file)
// ═════════════════════════════════════════

/// Lightweight struct to pass data between methods in this file
private struct SavedArticleData {
    let id        : String
    let title     : String
    let urlString : String
    let savedDate : String
    let sharedBy  : String?
    let sharedWith: [String]

    func toDictionary() -> [String: Any] {
        var dict: [String: Any] = [
            "id"        : id,
            "title"     : title,
            "urlString" : urlString,
            "savedDate" : savedDate,
            "sharedWith": sharedWith
        ]
        if let s = sharedBy { dict["sharedBy"] = s }
        return dict
    }
}

/// Mirrors the SavedArticle struct in ContentView so we can encode/decode the same JSON
private struct SavedArticleCodable: Codable {
    var id        : String
    var title     : String
    var urlString : String
    var savedDate : Date
    var sharedBy  : String?
    var sharedWith: [String]
}
